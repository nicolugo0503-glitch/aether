# --- Database (SQLite, works out of the box) ---
DATABASE_URL="file:./dev.db"

# --- Auth (safe default for local dev) ---
AUTH_SECRET="aether-local-dev-secret-change-in-production"
AUTH_URL="http://localhost:3000"

# --- OpenAI ---
# GET YOUR KEY AT: https://platform.openai.com/api-keys
# Without this, agents will error when you try to run them
OPENAI_API_KEY="sk-your-openai-key-here"
OPENAI_MODEL="gpt-4o-mini"

# --- Stripe (optional - only needed for real billing) ---
STRIPE_SECRET_KEY="sk_test_placeholder"
STRIPE_WEBHOOK_SECRET="whsec_placeholder"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_placeholder"
STRIPE_PRICE_STARTER=""
STRIPE_PRICE_GROWTH=""
STRIPE_PRICE_SCALE=""

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
